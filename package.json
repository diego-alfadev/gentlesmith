{
  "name": "gentlesmith",
  "version": "0.3.0-beta.12",
  "description": "Compose reusable prompt fragments into local AI-agent config overlays. Standalone or as a gentle-ai customization layer.",
  "type": "module",
  "bin": {
    "gentlesmith": "bin/distribute.ts"
  },
  "files": [
    "bin/",
    "src/",
    "fragments/",
    "presets/",
    "profiles/blank.yaml",
    "profiles/jarvis.yaml",
    "profiles/surgical.yaml",
    "targets/agents.yaml",
    "targets/antigravity.yaml",
    "targets/claude.yaml",
    "targets/codex.yaml",
    "targets/cursor.yaml",
    "targets/opencode.yaml",
    "README.md",
    "PROFILE_V1.md",
    "SETUP.md",
    "DEMO.md",
    "GENTLE_AI_CONTRACT.md",
    "GENTLE_AI_VALUE_PROPOSITION.md",
    "ROADMAP.md"
  ],
  "scripts": {
    "distribute": "bun run bin/distribute.ts",
    "pack:check": "bun pm pack --dry-run",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^7",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^6.0.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/diego-alfadev/gentlesmith.git"
  },
  "publishConfig": {
    "tag": "beta"
  }
}
